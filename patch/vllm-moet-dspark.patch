+        "target_hidden_size",
+        "mask_token_id",
+        "markov_rank",
+        "markov_head_type",
+        "block_size",
+        "enable_confidence_head",
+        "confidence_head_with_markov",
+    ):
+        if config_dict.get(key) is not None:
+            pre_trained_config[key] = config_dict[key]
